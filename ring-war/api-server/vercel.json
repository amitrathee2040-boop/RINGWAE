{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "echo 'no build step - Vercel bundles api/[...slug].ts'",
  "functions": {
    "api/[...slug].ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://ringwae-admin.vercel.app" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Requested-With, Accept, Origin" },
        { "key": "Access-Control-Max-Age", "value": "86400" },
        { "key": "Vary", "value": "Origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/health", "destination": "/api" },
    { "source": "/", "destination": "/api" }
  ]
}
